{
  "name": "@thumbnailjs/core",
  "version": "0.1.0",
  "description": "Tiny browser-only library that turns any file into a thumbnail",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thumbnailjs/core.git"
  },
  "bugs": {
    "url": "https://github.com/thumbnailjs/core/issues"
  },
  "homepage": "https://github.com/thumbnailjs/core#readme",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "tsup"
  },
  "keywords": [
    "thumbnail",
    "preview",
    "image",
    "video",
    "pdf",
    "browser",
    "offline",
    "client-side"
  ],
  "license": "MIT",
  "dependencies": {
    "pdfjs-dist": "^5.6.205"
  },
  "devDependencies": {
    "@vitest/browser": "^2.1.9",
    "playwright": "^1.59.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0",
    "webdriverio": "^9.27.0"
  },
  "sideEffects": false
}
